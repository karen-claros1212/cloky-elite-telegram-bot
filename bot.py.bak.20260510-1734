    for key in ["HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY", "http_proxy", "https_proxy", "all_proxy"]:
        env.pop(key, None)
    return env


# ============================================================================
# Parser de stream-json de Claude Code CLI
# ============================================================================

def parse_stream_line(line: str) -> tuple[str | None, str | None]:
    """
    Returns (visible_text, status_text).
    Tolerante a variantes de schema: walk recursivo sin asumir estructura rígida.
    La deduplicación se hace AFUERA en run_claude_task (Patch 4).
    """
    try:
        obj = json.loads(line)
    except Exception:
        return None, None

    event_type = str(obj.get("type", ""))

    if event_type in {"system", "init"}:
        return None, "Inicializando..."

    if event_type in {"tool_use", "tool"}:
        name = obj.get("name") or obj.get("tool_name") or "tool"
        return None, f"Usando herramienta: {name}"

    if event_type in {"tool_result"}:
        return None, "Herramienta completada"

    if event_type in {"error"}:
        return f"ERROR: {obj}", "Error"

    text_parts: list[str] = []

    def walk(value: Any) -> None:
        if isinstance(value, dict):
            block_type = value.get("type")
            if block_type == "text" and isinstance(value.get("text"), str):
                text_parts.append(value["text"])
            elif "result" in value and isinstance(value["result"], str):
                text_parts.append(value["result"])
            elif "content" in value:
                walk(value["content"])
            else:
                for child in value.values():
                    walk(child)
        elif isinstance(value, list):
            for child in value:
                walk(child)

    if event_type in {"assistant", "message", "result"}:
        walk(obj)

    text = "\n".join(t.strip() for t in text_parts if t and t.strip()).strip()
    return (text or None), None


# ============================================================================
# Ejecutor principal de Claude Code (Patch 3 + Patch 4)
# ============================================================================

def run_claude_task(user_id: str, chat_id: int, message_id: int, user_text: str) -> None:
    prompt = build_prompt(user_id, user_text)
    append_session(user_id, "user", user_text)

    # v1.2: Construir command con flag de auto-aprobación si está habilitado.
    # El sandbox systemd (Patch 6) limita el alcance de cualquier comando
    # destructivo a /home/jesus/cloky-elite-telegram-bot/workspace.
    command = [CLAUDE_BIN]
    if CLAUDE_AUTO_APPROVE:
        # --dangerously-skip-permissions: Claude Code ejecuta tools sin pedir
        # confirmación. Es seguro DENTRO del sandbox systemd.
        command.append("--dangerously-skip-permissions")
    command.extend([
        "--model", CLAUDE_MODEL,
        "--print",
        "--output-format", "stream-json",
        "--verbose",
        prompt,
    ])

    log(f"START_TASK user={user_id} auto_approve={CLAUDE_AUTO_APPROVE} workspace={WORKSPACE_DIR}")

    env = build_claude_env()

    stdout_lines: list[str] = []
    stderr_lines: list[str] = []
    visible_parts: list[str] = []
    status = "Procesando con Claude Code..."

    try:
        process = subprocess.Popen(
            command,
            cwd=str(WORKSPACE_DIR),
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            bufsize=1,
            preexec_fn=os.setsid if hasattr(os, "setsid") else None,
        )

        # Patch 3: reemplaza el slot "PENDING" reservado por handle_update.
        with task_lock:
            running_tasks[user_id] = RunningTask(user_id=user_id, chat_id=chat_id, process=process)

        q: queue.Queue[tuple[str, str]] = queue.Queue()

        def reader(stream: Any, label: str) -> None:
            try:
                for raw in iter(stream.readline, ""):
                    q.put((label, raw.rstrip("\n")))
            finally:
                q.put((label, "__EOF__"))

        threading.Thread(target=reader, args=(process.stdout, "stdout"), daemon=True).start()
        threading.Thread(target=reader, args=(process.stderr, "stderr"), daemon=True).start()

        eof_count = 0
        started = time.time()
        last_progress = time.time()

        while True:
            if time.time() - started > CLAUDE_TIMEOUT_SECONDS:
                raise TimeoutError(f"Claude Code timeout after {CLAUDE_TIMEOUT_SECONDS}s")

            if process.poll() is not None and eof_count >= 2:
                break

            try:
                label, line = q.get(timeout=1)
            except queue.Empty:
                if time.time() - last_progress >= PROGRESS_INTERVAL:
                    send_chat_action(chat_id)
                    last_progress = time.time()
                continue

            if line == "__EOF__":
                eof_count += 1
                continue

            if label == "stdout":
                stdout_lines.append(line)
                visible, new_status = parse_stream_line(line)
                if new_status:
                    status = new_status
                    # actualiza last_status para /status en vivo
                    with task_lock:
                        task = running_tasks.get(user_id)
                        if isinstance(task, RunningTask):
                            task.last_status = new_status
                            task.last_progress_at = time.time()
                if visible:
                    visible_parts.append(visible)
            else:
                stderr_lines.append(line)
                if "error" in line.lower() or "timeout" in line.lower():
                    status = "Claude Code reportó evento en stderr"

            if time.time() - last_progress >= PROGRESS_INTERVAL:
                send_chat_action(chat_id)
                last_progress = time.time()

        return_code = process.wait(timeout=5)
        stdout_text = "\n".join(stdout_lines)
        stderr_text = "\n".join(stderr_lines)

        # Patch 4: dedup por hash sha256. parse_stream_line con walk() recursivo
        # puede emitir el mismo texto desde content[].text y message.content[].text.
        seen_hashes: set[str] = set()
        unique_parts: list[str] = []
        for part in visible_parts:
            normalized = part.strip()
            if not normalized:
                continue
            h = hashlib.sha256(normalized.encode("utf-8")).hexdigest()
            if h in seen_hashes:
                continue
            seen_hashes.add(h)
            unique_parts.append(normalized)

        final_text = "\n\n".join(unique_parts).strip()

        if not final_text:
            final_text = fallback_from_outputs(stdout_text, stderr_text, return_code)

        if return_code != 0:
            final_text = f"Claude Code terminó con código {return_code}.\n\n{final_text}"

        # Redacción defensiva final antes de enviar a Telegram.
        final_text = redact(final_text)

        append_session(user_id, "assistant", final_text)
        send_message(chat_id, final_text, reply_to_message_id=message_id)
        log(f"END_TASK user={user_id} return_code={return_code} content_len={len(final_text)}")

    except Exception as exc:
        error_text = f"Error ejecutando Claude Code:\n{type(exc).__name__}: {exc}"
        log(redact(error_text + "\n" + traceback.format_exc()))
        send_message(chat_id, redact(error_text), reply_to_message_id=message_id)

    finally:
        # Patch 3: limpia tanto RunningTask como slot PENDING huérfano si hubo
        # excepción antes del Popen exitoso.
        with task_lock:
            running_tasks.pop(user_id, None)


# ============================================================================
# Fallback redactado (Patch 1)
# ============================================================================

def fallback_from_outputs(stdout_text: str, stderr_text: str, return_code: int | None) -> str:
    """
    Evita Telegram '(sin contenido visible)' devolviendo info operativa.
    SIEMPRE redacta antes de retornar (Patch 1).
    """
    candidates: list[str] = []

    for raw in stdout_text.splitlines():
        try:
            obj = json.loads(raw)
        except Exception:
            continue
        if isinstance(obj, dict):
            for key in ["result", "summary", "message"]:
                value = obj.get(key)
                if isinstance(value, str) and value.strip():
                    candidates.append(value.strip())

    if candidates:
        return redact("\n\n".join(candidates)[-12000:])

    clean_stdout = stdout_text.strip()
    clean_stderr = stderr_text.strip()

    fallback = [
        "Claude Code finalizó sin mensaje visible.",
        f"return_code={return_code}",
    ]

    if clean_stdout:
        fallback.append("stdout final:\n" + redact(clean_stdout[-6000:]))
    if clean_stderr:
        fallback.append("stderr final:\n" + redact(clean_stderr[-6000:]))

    return "\n\n".join(fallback)


