def build_claude_env() -> dict[str, str]:
    env = os.environ.copy()
    env.update(
        {
            "ANTHROPIC_BASE_URL": QWEN_BASE_URL,
            "ANTHROPIC_API_KEY": QWEN_API_KEY,
            "ANTHROPIC_AUTH_TOKEN": QWEN_API_KEY,
