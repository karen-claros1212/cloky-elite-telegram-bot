{
  "_comment": "Claude Code global settings — verificado contra documentación oficial 2026-06-03 (v1.9.0). Path: ~/.claude/settings.json. Estos valores aplican a TODA sesión de Claude Code en el sistema. CLI flags y env vars del shell tienen precedencia sobre este archivo, pero ese orden permite que bot.py los herede vía .env. NO modifica llama.cpp/TurboQuant: solo configura el CLI claude.",

  "model": "sonnet",

  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "MAX_THINKING_TOKENS": "31999",
    "CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY": "8",

    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_TIMEOUT_MS": "1800000",
    "BASH_MAX_OUTPUT_LENGTH": "50000",

    "MCP_TIMEOUT": "60000",
    "MCP_TOOL_TIMEOUT": "120000",
    "MAX_MCP_OUTPUT_TOKENS": "32000",

    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_TELEMETRY": "1",
    "DO_NOT_TRACK": "1"
  },

  "permissions": {
    "_comment_allow": "v1.9.0 — Allowlist granular. Estos comandos NO piden approval ni siquiera en modo default/acceptEdits. Eso permite que Edit y Auto modes del bot funcionen sin loops para tareas comunes. Comandos no listados siguen pidiendo approval (en modo Bypass se saltean igual, en Plan no se ejecutan).",
