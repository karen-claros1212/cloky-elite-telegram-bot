# ============================================================================
# Cloky Elite Telegram Bot v2.2.1 — Configuración
# ============================================================================
# Arquitectura: Telegram → bot.py → Claude Code CLI → llama-server :8080
# Sin proxy intermedio. Sin adapter_proxy.py. Sin FORCE_PERMISSION_MODE.
# ============================================================================


# === Telegram (REQUERIDO) ===
TELEGRAM_BOT_TOKEN="REEMPLAZAR_CON_TOKEN_DE_BOTFATHER"
ALLOWED_TELEGRAM_USER_ID="8166253211"


# === Backend local Anthropic-compatible (REQUERIDO) ===
# El bot se conecta DIRECTO a este endpoint. No usa proxy intermedio.
ANTHROPIC_BASE_URL="http://127.0.0.1:8080"
ANTHROPIC_API_KEY="sk-mor...pace"
ANTHROPIC_AUTH_TOKEN="sk-mor...pace"

# Modelos: el string se envía literal en el campo "model".
# Tu llama-server decide qué modelo carga; el bot no toca .gguf.
ANTHROPIC_MODEL="sonnet"
ANTHROPIC_DEFAULT_SONNET_MODEL="Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf"
ANTHROPIC_DEFAULT_OPUS_MODEL="Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf"
ANTHROPIC_DEFAULT_HAIKU_MODEL="Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf"


# === Claude Code CLI ===
CLAUDE_BIN="claude"
CLAUDE_MODEL="sonnet"
CLAUDE_AUTO_APPROVE="true"


# === Tokens — DEFAULTS ===
CLAUDE_CODE_MAX_OUTPUT_TOKENS="32000"
MAX_THINKING_TOKENS="31999"
CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="8"


# === Bash timeouts ===
BASH_DEFAULT_TIMEOUT_MS="600000"
BASH_MAX_TIMEOUT_MS="1800000"
BASH_MAX_OUTPUT_LENGTH="50000"


# === Telemetría ===
CLAUDE_CODE_ATTRIBUTION_HEADER="0"
CLAUDE_CODE_ENABLE_TELEMETRY="0"
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="1"
DISABLE_TELEMETRY="1"
DO_NOT_TRACK="1"
DISABLE_AUTOUPDATER="1"


# === MCP ===
MCP_TIMEOUT="60000"
MCP_TOOL_TIMEOUT="120000"
MAX_MCP_OUTPUT_TOKENS="32000"


# === Aislamiento ===
BOT_HOME="/home/jesus/cloky-elite-telegram-bot"
CLAUDE_WORKSPACE="/home/jesus/cloky-elite-telegram-bot/workspace"


# === Runtime del BOT ===
# Timeout del bot.py contra el subprocess claude (30 min)
CLAUDE_TIMEOUT_SECONDS="1800"
TELEGRAM_POLL_TIMEOUT="45"
PROGRESS_INTERVAL_SECONDS="20"
MAX_CONTEXT_MESSAGES="12"


# === v1.7 Persistencia nativa Claude Code ===
# El bot usa --session-id (primer turno) y --resume (continuación).
# No usa --fork-session (rota el ID en cada turno).
CLAUDE_DEFAULT_PERMISSION_MODE="bypassPermissions"
CLAUDE_MAX_TURNS="50"


# === v1.8 Botones inline ===
CLAUDE_INLINE_BUTTONS="true"


# === v1.9 Usage tracking ===
USAGE_TRACKING_ENABLED="true"
USAGE_COST_INPUT_PER_M="3.0"
USAGE_COST_OUTPUT_PER_M="15.0"
APPROVAL_BUTTONS_ENABLED="false"


# === NO modificar ===
NO_PROXY="localhost,127.0.0.1,::1"
no_proxy="localhost,127.0.0.1,::1"
