# ClokyOS Pilot - Environment Variables
# Copiar a .env y ajustar valores

APP_NAME="ClokyOS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://localhost

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=clokyos_pos
DB_USERNAME=clokyos
DB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRATION=60
JWT_REFRESH_EXPIRATION=1440

# Multi-tenancy
MULTI_TENANCY_ENABLED=true
TENANT_DB_PREFIX=pos_user_

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=clokyos@mascontrol.com
MAIL_FROM_NAME="$APP_NAME"

# DIAN (Facturacion Electronica)
DIAN_URL=https://vpfe.dian.gov.co/WcfDianCustomerServices.svc
DIAN_CERTIFICATE_PATH=/var/www/html/storage/app/certificates/dian.p12
DIAN_CERTIFICATE_PASSWORD=
DIAN_ENVIRONMENT=HABILITACION

# Storage
STORAGE_PATH=/var/www/html/storage
STORAGE_URL=/storage

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=info

# Security
CORS_ALLOWED_ORIGINS=https://localhost
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
