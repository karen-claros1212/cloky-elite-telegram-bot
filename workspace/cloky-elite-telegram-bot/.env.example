# ============================================================================
# Cloky Elite Telegram Bot v1.3 — Configuración OPTIMIZADA
# ============================================================================
# Valores basados en documentación oficial Claude Code al 2026-05-10:
#   https://code.claude.com/docs/en/env-vars
#   https://docs.claude.com/en/docs/claude-code/settings
#
# Defaults oficiales documentados:
#   CLAUDE_CODE_MAX_OUTPUT_TOKENS:     default 32000, max 64000
#   BASH_DEFAULT_TIMEOUT_MS:           default 120000 (2 min)
#   BASH_MAX_TIMEOUT_MS:               default 600000 (10 min)
#   CLAUDE_CODE_IDLE_TOKEN_THRESHOLD:  default 100000
#   CLAUDE_CODE_IDLE_THRESHOLD_MINUTES: default 75
# ============================================================================


# === Telegram (REQUERIDO) ===
TELEGRAM_BOT_TOKEN="REEMPLAZAR_CON_TOKEN_DE_BOTFATHER"
ALLOWED_TELEGRAM_USER_ID="8166253211"


# === Backend local Anthropic-compatible (REQUERIDO) ===
# El bot SOLO consume este endpoint como cliente HTTP.
# NO modifica llama.cpp / TurboQuant / vLLM.
ANTHROPIC_BASE_URL="http://127.0.0.1:8080"
ANTHROPIC_API_KEY="sk-morgan-workspace"
ANTHROPIC_AUTH_TOKEN="sk-morgan-workspace"

# Modelos: el string se envía literal en el campo "model".
# Tu llama-server decide qué modelo carga; el bot no toca .gguf.
ANTHROPIC_MODEL="sonnet"
ANTHROPIC_DEFAULT_SONNET_MODEL="Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf"
ANTHROPIC_DEFAULT_OPUS_MODEL="Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf"
ANTHROPIC_DEFAULT_HAIKU_MODEL="Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q4_K_M.gguf"


# === Claude Code CLI — OPTIMIZADO ===

# Path al binario claude.
CLAUDE_BIN="claude"
CLAUDE_MODEL="sonnet"

# Modo AUTÓNOMO (v1.2).
CLAUDE_AUTO_APPROVE="true"


# === Tokens — DEFAULTS OFICIALES ===

# Default oficial 32000, máximo 64000.
# NO subir más allá de 32000 a menos que estés seguro de que Qwen lo soporta;
# Opus 4.6 oficial tiene bug en 64K (issue #24159 en anthropics/claude-code).
# Con tu Qwen3.6-A3B-35B en ctx 65536, 32000 deja ~33K libres para input.
CLAUDE_CODE_MAX_OUTPUT_TOKENS="32000"

# Presupuesto de "extended thinking" cuando el modelo razona internamente.
# 31999 es el observado en producción (issue #24159 lo muestra como maxThinkingTokens).
# Si Qwen no implementa extended thinking, esta variable es inocua.
MAX_THINKING_TOKENS="31999"

# Concurrencia de tool calls del agent loop.
# Tu Ryzen 9 9950X3D tiene 16 cores físicos / 32 hilos. 8 es seguro y útil.
# El default no documentado oficialmente parece ser 4.
CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY="8"


# === Bash timeouts — CRÍTICO ===
# Tu Qwen local es más lento que la API de Anthropic, y tareas como
# 'npm install', 'pip install', 'make' pueden tardar minutos.
# Documentación oficial: default 120000 (2 min) → INSUFICIENTE.

# 10 minutos para comandos largos (npm install, builds, etc.)
BASH_DEFAULT_TIMEOUT_MS="600000"

# 30 minutos como techo absoluto que el modelo no puede sobrepasar.
BASH_MAX_TIMEOUT_MS="1800000"

# Salida máxima de un comando bash antes de truncar (evita llenar contexto
# con un cat de un log gigante). Default documentado: 30000 chars.
BASH_MAX_OUTPUT_LENGTH="50000"


# === Telemetría y privacidad ===

# Apagar todo lo no esencial (ya estaba bien configurado).
CLAUDE_CODE_ATTRIBUTION_HEADER="0"
CLAUDE_CODE_ENABLE_TELEMETRY="0"
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"

# Habilitar discovery de modelos del gateway (útil para proxies locales).
CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="1"

# Disable nuevas funciones que requieren red externa.
DISABLE_TELEMETRY="1"
DO_NOT_TRACK="1"

# Disable auto-update del CLI (evita cambios durante operación 24/7).
DISABLE_AUTOUPDATER="1"


# === MCP (Model Context Protocol) ===
# Si Claude Code intenta cargar servers MCP, estos timeouts evitan que cuelgue.
MCP_TIMEOUT="60000"
MCP_TOOL_TIMEOUT="120000"
MAX_MCP_OUTPUT_TOKENS="32000"


# === Aislamiento de workspace ===
BOT_HOME="/home/jesus/cloky-elite-telegram-bot"
CLAUDE_WORKSPACE="/home/jesus/cloky-elite-telegram-bot/workspace"


# === v1.6 Sprint 2 ===

# S2.1 Streaming incremental a Telegram
# El bot edita el mensaje progresivamente mientras Claude genera output.
# Ves el resultado en vivo en lugar de esperar al final.
STREAM_ENABLED="true"
STREAM_EDIT_INTERVAL="1.5"     # segundos entre edits (rate limit Telegram)
STREAM_MIN_CHUNK_LEN="200"     # chars antes de empezar a editar

# S2.2 Manejo de archivos subidos
# Mandá fotos, docs, audio, video por Telegram y se descargan a workspace/uploads/.
# Si la imagen/doc tiene caption, ésta se interpreta como tarea con el path inyectado.
MAX_UPLOAD_BYTES="52428800"     # 50 MB

# S2.3 Multi-proyecto con /cd
# Lista de proyectos accesibles vía /cd <nombre>. Formato:
#   "nombre1:/path/absoluto/1,nombre2:/path/absoluto/2"
# IMPORTANTE: en modo strict del sandbox systemd, estos paths deben estar
# expuestos via BindPaths en install_service.sh. En modo open, no hace falta.
# Dejar vacío para deshabilitar /cd (usuario siempre opera en workspace).
ALLOWED_PROJECTS=""
# Ejemplo:
# ALLOWED_PROJECTS="cobravivo:/home/jesus/projects/cobravivo,viper:/home/jesus/VIPER_HFT_Bot"

# === Runtime del BOT (variables propias del bot, no de Claude Code) ===

# CRÍTICO: este timeout es del bot.py contra el subprocess claude.
# Debe ser ≥ BASH_MAX_TIMEOUT_MS, si no el bot mata claude antes de que
# bash complete. 1800s = 30 min, alineado con BASH_MAX_TIMEOUT_MS.
CLAUDE_TIMEOUT_SECONDS="1800"

# Polling Telegram.
TELEGRAM_POLL_TIMEOUT="45"

# Cada cuántos segundos enviar "typing..." mientras Claude trabaja.
PROGRESS_INTERVAL_SECONDS="20"

# Cuántos mensajes de historial pasar a Claude como contexto.
# Con max_tokens 32K hay espacio sobrado.
MAX_CONTEXT_MESSAGES="12"

# v1.4: Umbral de tarea "larga" en segundos. Tareas que duren más que
# esto enviarán notificación SONORA a Telegram al terminar.
# Por defecto 120s. Tareas más cortas se envían silenciosas.
# (Estos valores están hardcodeados en bot.py actualmente, no son env vars
# todavía; este comentario es informativo.)


# === NO modificar bajo ningún concepto ===
NO_PROXY="localhost,127.0.0.1,::1"
no_proxy="localhost,127.0.0.1,::1"
