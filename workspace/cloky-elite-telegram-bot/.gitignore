# Cloky Elite Telegram Bot - .gitignore

# Configuración local con tokens
.env
.env.local
.env.*.local

# Estado de runtime
state/
logs/
workspace/uploads/
workspace/CLAUDE.md
.sandbox_mode

# Backups generados por install_service.sh
*.bak
*.bak.v*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtualenvs (no debería haber, pero por si acaso)
venv/
env/
ENV/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# systemd unit generado
# (el unit real va en ~/.config/systemd/user/, no en el repo)

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Documentation builds
docs/_build/
site/
